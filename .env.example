# Copy this file to .env or export these variables in your shell before running
# scripts that access local data or external services.

# Required only for VirusTotal collection scripts.
VT_API_KEY=

# Local data roots.
DIB_DATA_ROOT=/path/to/data
APK_DIR=/path/to/APKs
HASH_FILE=/path/to/hashes.csv
PKG_MAP_FILE=/path/to/md5_hashes.csv
PAPER_FILE=/path/to/corrected_permacts.csv

# Raw response directories.
VT_JSON_DIR=/path/to/virustotal_v3_json
VT_RELIABLE_JSON_DIR=/path/to/virustotal_v3_reliable_json
VT_FIRST_TIME_BENIGN_DIR=/path/to/virustotal_first_time_benign_json
VT_LEGACY_JSON_DIR=/path/to/virustotal_v2_json
QUARK_SCAN_DIR=/path/to/quark_first_scan_json
QUARK_RESCAN_DIR=/path/to/quark_rescan_json
QK_RESCANNED_DIR=/path/to/rescanned_quark_json

# Derived outputs and caches.
DATASET_DIR=/path/to/derived_datasets
CACHE_DIR=/path/to/cache
FIGURE_DIR=/path/to/figures

# Quark-Engine rule directory.
QUARK_RULE_DIR=/path/to/quark-rules/rules
